<%= content_for :head do %>
  <meta name="description" content="Re&ccedil;ois ma vid&eacute;o gratuite : la m&eacute;thode pour attirer les bonnes personnes sur les r&eacute;seaux.">
<% end %>

<section class="min-h-screen flex items-center justify-center" style="background:radial-gradient(ellipse at top, var(--color-blush-soft), var(--color-paper) 60%)" data-controller="landing-form">
  <div class="w-full max-w-xl mx-auto px-6 py-16">

    <%# Formulaire %>
    <div data-landing-form-target="form">
      <div class="text-center mb-10">
        <p class="font-accent uppercase mb-4" style="font-size:13px;letter-spacing:3px;font-weight:600;color:var(--color-taupe)">Bienvenue</p>
        <h1 class="font-display text-4xl md:text-5xl font-bold leading-tight mb-6" style="color:var(--color-ink)">
          R&eacute;v&eacute;ler votre authenticit&eacute;<br>sur les r&eacute;seaux
        </h1>
        <div class="w-16 h-1 mx-auto mb-6" style="background:var(--color-primary);border-radius:2px"></div>
        <p class="font-body text-lg md:text-xl leading-relaxed" style="color:var(--color-ink-soft)">
          Re&ccedil;ois ma vid&eacute;o gratuite&nbsp;:<br>
          <span class="font-body text-xl md:text-2xl font-medium italic" style="color:var(--color-ink)">
            La m&eacute;thode pour attirer les bonnes personnes sur les r&eacute;seaux sans y passer ta vie
          </span>
        </p>
      </div>

      <%# Erreurs %>
      <p data-landing-form-target="errorMessage"
         class="hidden text-sm font-body text-center mb-4 rounded-xl px-4 py-2" style="background:rgba(252,165,165,0.15);color:#c0392b"></p>

      <form action="<%= subscribers_path %>" method="post" data-action="submit->landing-form#submit" class="space-y-4">
        <input data-landing-form-target="firstName"
               type="text" name="subscriber[first_name]" required
               placeholder="Ton pr&eacute;nom"
               class="w-full px-6 py-4 rounded-xl font-body text-lg focus:outline-none transition-colors" style="border:1px solid rgba(150,129,107,0.25);background:#fff;color:var(--color-ink)">
        <input data-landing-form-target="email"
               type="email" name="subscriber[email]" required
               placeholder="Ton adresse email"
               class="w-full px-6 py-4 rounded-xl font-body text-lg focus:outline-none transition-colors" style="border:1px solid rgba(150,129,107,0.25);background:#fff;color:var(--color-ink)">
        <button data-landing-form-target="submit" type="submit"
                class="btn-primary font-accent uppercase w-full px-6 py-4 text-lg cursor-pointer" style="letter-spacing:1.5px">
          Je re&ccedil;ois ma vid&eacute;o gratuite &rarr;
        </button>
      </form>

      <p class="font-body text-xs text-center mt-4" style="color:var(--color-taupe)">
        100% gratuit &bull; Aucun spam &bull; Juste de la valeur
      </p>
    </div>

    <%# Confirmation %>
    <div data-landing-form-target="success" class="hidden text-center">
      <div class="w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6" style="background:var(--color-blush)">
        <svg class="w-10 h-10" style="color:var(--color-primary)" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
        </svg>
      </div>
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-4" style="color:var(--color-ink)">
        C'est dans ta bo&icirc;te mail !
      </h2>
      <p class="font-body text-lg leading-relaxed mb-8" style="color:var(--color-ink-soft)">
        V&eacute;rifie tes spams si tu ne la vois pas.<br>
        &Agrave; tout de suite dans la vid&eacute;o !
      </p>
      <a href="/" class="btn-secondary inline-flex items-center justify-center px-8 py-3 font-accent uppercase" style="font-size:13px;letter-spacing:1.5px">
        Visiter le site
      </a>
    </div>

  </div>
</section>
