<%= content_for :head do %>
  <meta name="description" content="Amandine Atelier Digital — Social Media Manager. Accompagnement, autonomie et stratégie réseaux sociaux pour révéler votre authenticité avec une communication digitale humaine et sur mesure.">
  <% if elfsight_app_id.present? %>
    <script src="https://elfsightcdn.com/platform.js" async></script>
  <% end %>
<% end %>

<%= render "shared/navbar", active: "accueil" %>

<%# ═══════════════════════════════ BANDEAU DÉFILANT (marquee) — fixe sous la navbar ═══════════════════════════════ %>
<div class="fixed inset-x-0 z-30 overflow-hidden" style="top:70px;padding:10px 0;background:var(--color-rose)">
  <div class="marquee-track">
    <% 2.times do %>
      <span class="font-accent flex items-center gap-7 whitespace-nowrap" style="font-size:12.5px;letter-spacing:1.5px;padding:0 26px;color:rgba(255,255,255,0.80)">
        <%= c("marquee_prefix") %>
        <span class="font-display" style="font-size:14px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;color:#ffffff"><%= c("marquee_highlight") %></span>
        <%= c("marquee_suffix") %>
        <span style="color:rgba(255,255,255,0.35)">—</span>
      </span>
    <% end %>
  </div>
</div>

<%# ═══════════════════════════════ HERO ═══════════════════════════════ %>
<section id="hero" class="overflow-hidden relative" style="background:var(--color-paper);padding-top:112px">
  <div class="grid lg:grid-cols-12 items-center" style="min-height:calc(100vh - 112px)">
    <%# Texte %>
    <div class="lg:col-span-7 px-6 lg:pl-16 xl:pl-24 lg:pr-12 py-16 lg:py-0" data-controller="reveal" data-reveal-direction="left">
      <p class="eyebrow mb-8"><%= c("hero_tagline") %></p>
      <h1 class="mb-8" style="font-family:var(--font-display);font-weight:700;font-size:clamp(38px,5vw,68px);line-height:1.04;letter-spacing:-0.02em;color:var(--color-ink)">
        <% title = c("hero_title") %>
        <%= raw ERB::Util.h(title).sub("authenticité", "<span style=\"color:var(--color-primary)\">authenticité</span>") %>
      </h1>
      <p class="font-body mb-12 max-w-xl" style="font-size:17px;color:var(--color-ink-soft);line-height:1.85">
        <%= c("hero_description") %>
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#offres" class="btn-primary btn-lg font-accent"><%= c("hero_cta_primary") %></a>
        <a href="<%= c("instagram_url") %>" target="_blank" rel="noopener noreferrer" class="btn-secondary btn-lg font-accent"><%= c("hero_cta_secondary") %></a>
      </div>
    </div>
    <%# Photo avec bloc décalé %>
    <div class="lg:col-span-5 px-6 lg:pr-16 xl:pr-24 pb-16 lg:py-0 flex justify-center lg:justify-end" data-controller="reveal" data-reveal-direction="right">
      <div class="photo-offset w-full max-w-md lg:max-w-none" data-controller="parallax" data-parallax-speed-value="0.06">
        <div class="overflow-hidden h-[380px] md:h-[520px] lg:h-[600px]" style="border-radius:26px">
          <% if c_image("hero_image") %>
            <%= image_tag c_image("hero_image"), class: "w-full h-full object-cover", style: "object-position:center top", alt: "Amandine Atelier Digital" %>
          <% else %>
            <%= image_tag "hero.png", class: "w-full h-full object-cover", style: "object-position:center top", alt: "Amandine Atelier Digital" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ═══════════════════════════════ BANDE STATS (sombre ou photo floutée) ═══════════════════════════════ %>
<section class="stat-band relative overflow-hidden <%= 'has-photo' if c_image('counters_image') %>">
  <% if c_image("counters_image") %>
    <%# Photo de fond floutée + voile sombre transparent (garde la lisibilité des chiffres) %>
    <div class="absolute inset-0" style="z-index:0">
      <%= image_tag c_image("counters_image"), class: "w-full h-full object-cover", style: "filter:blur(9px);transform:scale(1.12)", alt: "" %>
      <div class="absolute inset-0" style="background:rgba(242,217,230,0.45)"></div>
    </div>
  <% end %>
  <div class="relative max-w-[1100px] mx-auto px-6 py-14 md:py-20" style="z-index:1">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-10 sm:gap-6 divide-y sm:divide-y-0 sm:divide-x" style="border-color:rgba(172,97,103,0.22)">
      <% [1, 2, 3].each_with_index do |i, idx| %>
        <div class="text-center px-4 <%= 'pt-10 sm:pt-0' if idx > 0 %>" data-controller="reveal" data-reveal-direction="up" data-reveal-delay="<%= idx * 150 %>">
          <p class="stat-num">
            <span data-controller="counter"
                  data-counter-target-value="<%= c("counter#{i}_number") %>"
                  data-counter-suffix-value="<%= c("counter#{i}_suffix") %>"
                  data-counter-duration-value="2200">0</span>
          </p>
          <p class="stat-label"><%= c("counter#{i}_label") %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ═══════════════════════════════ PROBLÈME ═══════════════════════════════ %>
<section id="probleme" class="section-py" style="background:var(--color-paper)">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="max-w-3xl mb-16 lg:mb-20" data-controller="reveal" data-reveal-direction="up">
      <p class="eyebrow mb-6">Pour qui ?</p>
      <h2 class="h-lg" style="font-size:clamp(28px,3.8vw,46px)"><%= c("problem_title") %></h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <% [1, 2, 3].each_with_index do |i, idx| %>
        <div class="card-glass p-10" data-controller="reveal" data-reveal-direction="up" data-reveal-delay="<%= idx * 150 %>">
          <p class="index-num mb-6"><%= format('%02d', idx + 1) %></p>
          <h3 class="font-display mb-4" style="font-size:22px;font-weight:700;text-transform:uppercase;letter-spacing:-0.01em;color:var(--color-ink)"><%= c("problem_card#{i}_title") %></h3>
          <p class="font-body" style="font-size:15px;color:var(--color-ink-soft);line-height:1.8"><%= c("problem_card#{i}_text") %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ═══════════════════════════════ SOLUTION / À PROPOS ═══════════════════════════════ %>
<section id="solution" class="overflow-hidden section-py" style="background:var(--color-cream)">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-14 lg:gap-20 items-center">
      <%# Photo %>
      <div class="order-2 lg:order-1 flex justify-center lg:justify-start" data-controller="reveal" data-reveal-direction="left">
        <div class="photo-offset w-full max-w-md" data-controller="parallax" data-parallax-speed-value="0.06">
          <div class="overflow-hidden h-[420px] md:h-[520px]" style="border-radius:26px">
            <% if c_image("solution_image") %>
              <%= image_tag c_image("solution_image"), class: "w-full h-full object-cover", style: "object-position:center top", alt: "Amandine" %>
            <% else %>
              <%= image_tag "portrait.jpg", class: "w-full h-full object-cover", style: "object-position:center top", alt: "Amandine" %>
            <% end %>
          </div>
        </div>
      </div>
      <%# Texte %>
      <div class="order-1 lg:order-2" data-controller="reveal" data-reveal-direction="right">
        <p class="eyebrow mb-6"><%= c("solution_subtitle") %></p>
        <h2 class="h-lg mb-6" style="font-size:clamp(28px,3.8vw,46px)"><%= c("solution_title") %></h2>
        <p class="font-display mb-8" style="font-size:clamp(20px,2.2vw,26px);font-weight:600;color:var(--color-primary);line-height:1.35">
          <%= c("solution_tagline") %>
        </p>
        <div class="font-body space-y-5 mb-10" style="font-size:16px;color:var(--color-ink-soft);line-height:1.9">
          <p><%= c("solution_text1") %></p>
          <p><%= c("solution_text2") %></p>
        </div>
        <a href="#offres" class="btn-primary btn-lg font-accent inline-flex"><%= c("solution_cta").presence || "Voir les offres" %></a>
      </div>
    </div>
  </div>
</section>

<%# ═══════════════════════════════ OFFRES ═══════════════════════════════ %>
<section id="offres" class="section-py" style="background:var(--color-paper)">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16 lg:mb-20" data-controller="reveal" data-reveal-direction="up">
      <% if c("offers_tagline").present? %>
        <p class="eyebrow eyebrow-c mb-6"><%= c("offers_tagline") %></p>
      <% end %>
      <h2 class="h-lg" style="font-size:clamp(28px,3.8vw,46px)"><%= c("offers_title") %></h2>
    </div>

    <%
      offer_icons = [
        '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>',
        '<path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M14.5 9.5l-2 5-5 2 2-5z"/>',
        '<path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 00-.491 6.347A48.62 48.62 0 0112 20.904a48.62 48.62 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.636 50.636 0 00-2.658-.813A59.906 59.906 0 0112 3.493a59.903 59.903 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0112 13.489a50.702 50.702 0 017.74-3.342"/>'
      ]
      visible_offers = [2, 3, 4]
    %>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 items-stretch">
      <% visible_offers.each_with_index do |i, idx| %>
        <% recommended = c("offer#{i}_recommended") %>
        <% dark = recommended.present? %>
        <%
          ink_text   = dark ? "#ffffff" : "var(--color-ink)"
          soft_text  = dark ? "rgba(246,241,232,0.72)" : "var(--color-ink-soft)"
          taupe_text = dark ? "rgba(246,241,232,0.55)" : "var(--color-taupe)"
          price_col  = dark ? "#f2b8cd" : "var(--color-primary)"
          icon_bg    = dark ? "rgba(255,255,255,0.10)" : "var(--color-blush)"
          divider    = dark ? "rgba(246,241,232,0.15)" : "rgba(150,129,107,0.15)"
          card_cls   = dark ? "card-offer-dark" : "card-offer"
          link_col   = dark ? "#f2b8cd" : "var(--color-primary)"
        %>
        <div class="<%= card_cls %> p-8 lg:p-10 flex flex-col relative <%= 'lg:-translate-y-4' if dark %>" data-controller="reveal offer-modal" data-reveal-direction="up" data-reveal-delay="<%= idx * 150 %>" data-offer="offer<%= i %>" style="overflow:visible">
          <% if dark %>
            <div class="absolute" style="top:-14px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#d95c84,#ac6167);color:#fff;font-size:10px;font-weight:700;letter-spacing:2px;text-transform:uppercase;padding:6px 16px;border-radius:999px;white-space:nowrap;box-shadow:0 8px 20px rgba(217,92,132,0.4);z-index:2">
              <%= recommended %>
            </div>
          <% end %>
          <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-6" style="background:<%= icon_bg %>">
            <svg class="w-6 h-6" style="color:<%= price_col %>" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><%= raw offer_icons[idx] %></svg>
          </div>

          <p class="font-accent uppercase mb-2" style="font-size:11px;letter-spacing:2px;font-weight:600;color:<%= taupe_text %>"><%= c("offer#{i}_subtitle") %></p>
          <h3 class="font-display mb-3" style="font-size:24px;font-weight:700;text-transform:uppercase;letter-spacing:-0.01em;color:<%= ink_text %>"><%= c("offer#{i}_title") %></h3>
          <p class="font-display <%= c("offer#{i}_badge").present? ? 'mb-2' : 'mb-5' %>" style="font-size:24px;font-weight:700;color:<%= price_col %>;line-height:1.15"><%= c("offer#{i}_price") %></p>
          <% if c("offer#{i}_badge").present? %>
            <p class="font-accent mb-5 inline-flex items-center gap-1.5" style="font-size:11.5px;font-weight:600;color:<%= price_col %>;letter-spacing:0.3px">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M10 1l2.6 5.3 5.8.8-4.2 4.1 1 5.8L10 14.3 4.8 17l1-5.8L1.6 7.1l5.8-.8z"/></svg>
              <%= c("offer#{i}_badge") %>
            </p>
          <% end %>

          <% if c("offer#{i}_for_who").present? %>
            <div class="mb-5 pb-5" style="border-bottom:1px solid <%= divider %>">
              <p class="font-accent uppercase mb-1.5" style="font-size:10px;letter-spacing:2px;font-weight:600;color:<%= taupe_text %>">Pour qui ?</p>
              <p class="font-body" style="font-size:13px;color:<%= soft_text %>;line-height:1.6"><%= c("offer#{i}_for_who") %></p>
            </div>
          <% end %>

          <p class="font-body mb-8 flex-1" style="font-size:14px;color:<%= soft_text %>;line-height:1.8"><%= c("offer#{i}_text") %></p>

          <button type="button" data-action="offer-modal#open" class="inline-flex items-center font-accent hover:opacity-70 transition-opacity cursor-pointer mt-auto" style="font-size:13px;letter-spacing:1px;font-weight:600;color:<%= link_col %>;background:none;border:none;padding:0;text-align:left">En savoir plus &rarr;</button>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ── Modals offres ── %>
<% visible_offers.each_with_index do |i, idx| %>
  <div id="modal-offer<%= i %>" style="display:none;position:fixed;inset:0;z-index:50;align-items:center;justify-content:center;padding:20px">
    <div data-overlay style="position:absolute;inset:0;background:rgba(172,97,103,0.45);opacity:0;transition:opacity 0.3s ease"></div>
    <div data-panel style="position:relative;max-width:640px;width:100%;max-height:90vh;overflow-y:auto;background:#ffffff;border:1px solid rgba(217,92,132,0.25);border-radius:20px;padding:40px 32px;transform:translateY(30px);opacity:0;transition:transform 0.4s cubic-bezier(0.16,1,0.3,1), opacity 0.3s ease;box-shadow:0 30px 70px rgba(172,97,103,0.18)">
      <button data-close style="position:absolute;top:16px;right:16px;width:36px;height:36px;border-radius:50%;background:var(--color-blush);border:none;color:var(--color-rose);font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center">&times;</button>

      <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background:var(--color-blush)">
        <svg class="w-6 h-6" style="color:var(--color-primary)" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><%= raw offer_icons[idx] %></svg>
      </div>
      <p class="font-accent uppercase mb-2" style="font-size:11px;letter-spacing:2px;font-weight:600;color:var(--color-taupe)"><%= c("offer#{i}_subtitle") %></p>
      <h3 class="font-display mb-3" style="font-size:28px;font-weight:700;text-transform:uppercase;color:var(--color-ink);line-height:1.1"><%= c("offer#{i}_title") %></h3>
      <div class="inline-block px-4 py-2 mb-6" style="background:var(--color-blush);border-radius:999px">
        <span class="font-display" style="font-size:16px;font-weight:700;color:var(--color-rose)"><%= c("offer#{i}_price") %></span>
      </div>

      <% promesse = c("offer#{i}_promesse") %>
      <% if promesse.present? %>
        <p class="font-body mb-6" style="font-size:15px;color:var(--color-ink);line-height:1.7;font-style:italic">« <%= promesse %> »</p>
      <% end %>

      <% comprend_items = c("offer#{i}_comprend").to_s.split(/\r?\n/).map(&:strip).reject(&:empty?) %>
      <% if comprend_items.any? %>
        <div class="mb-6">
          <h4 class="font-accent uppercase mb-3" style="font-size:11px;letter-spacing:2px;font-weight:600;color:var(--color-taupe)">Ce que comprend l'offre</h4>
          <ul class="space-y-2">
            <% comprend_items.each do |item| %>
              <li class="flex items-start gap-2.5">
                <svg class="w-4 h-4 mt-0.5 shrink-0" style="color:var(--color-primary)" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span class="font-body" style="font-size:14px;color:var(--color-ink);line-height:1.6"><%= item %></span>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% benefice = c("offer#{i}_benefice") %>
      <% if benefice.present? %>
        <div class="px-5 py-4 mb-8" style="background:var(--color-blush-soft);border-left:3px solid var(--color-primary);border-radius:6px">
          <h4 class="font-accent uppercase mb-1.5" style="font-size:10px;letter-spacing:2px;font-weight:600;color:var(--color-taupe)">Bénéfice client</h4>
          <p class="font-body" style="font-size:14px;color:var(--color-ink);line-height:1.6;font-weight:500"><%= benefice %></p>
        </div>
      <% end %>

      <button type="button" data-controller="contact-modal" data-action="click->contact-modal#open" class="btn-primary btn-lg font-accent inline-flex items-center justify-center">Me contacter pour cette offre</button>
    </div>
  </div>
<% end %>

<%# ═══════════════════════════════ BANDE CTA (rose pleine ou photo floutée) ═══════════════════════════════ %>
<section class="cta-band relative overflow-hidden">
  <% if c_image("cta_image") %>
    <%# Photo de fond floutée (remplace le dégradé) + voile rose pour la lisibilité %>
    <div class="absolute inset-0" style="z-index:0">
      <%= image_tag c_image("cta_image"), class: "w-full h-full object-cover", style: "filter:blur(9px);transform:scale(1.12)", alt: "" %>
      <div class="absolute inset-0" style="background:linear-gradient(135deg, rgba(217,92,132,0.72), rgba(172,97,103,0.80))"></div>
    </div>
  <% end %>
  <div class="relative max-w-[1000px] mx-auto px-6 py-20 lg:py-28 text-center" style="z-index:1" data-controller="reveal" data-reveal-direction="scale">
    <% if c("cta_eyebrow").present? %>
      <p class="eyebrow eyebrow-c eyebrow-light mb-6" style="color:rgba(255,255,255,0.85)"><%= c("cta_eyebrow") %></p>
    <% end %>
    <h2 class="font-display mb-8" style="font-size:clamp(30px,4.2vw,52px);font-weight:700;text-transform:uppercase;letter-spacing:-0.02em;line-height:1.05;color:#ffffff">
      <%= c("cta_title").presence || "Prête à donner une vraie voix à votre communication ?" %>
    </h2>
    <% if c("cta_description").present? %>
      <p class="font-body mb-12 max-w-xl mx-auto" style="font-size:17px;color:rgba(255,255,255,0.9);line-height:1.8">
        <%= c("cta_description") %>
      </p>
    <% end %>
    <button type="button" data-controller="contact-modal" data-action="click->contact-modal#open" class="btn-invert btn-lg font-accent" style="cursor:pointer"><%= c("cta_button").presence || "Prendre contact" %></button>
  </div>
</section>

<%# ═══════════════════════════════ INSTAGRAM ═══════════════════════════════ %>
<section id="feed" class="section-py" style="background:var(--color-cream)">
  <div class="max-w-[1000px] mx-auto px-6">
    <div class="text-center mb-16" data-controller="reveal">
      <p class="eyebrow eyebrow-c mb-5">Réseaux sociaux</p>
      <h3 class="h-lg mb-4" style="font-size:clamp(28px,3.6vw,42px)">Retrouvez-moi sur Instagram</h3>
      <a href="<%= c("instagram_url") %>" target="_blank" rel="noopener noreferrer"
         class="font-display hover:opacity-60 transition-opacity" style="font-size:22px;font-weight:700;color:var(--color-primary)">
        <%= c("instagram_handle") %>
      </a>
    </div>

    <% embed_id = elfsight_app_id %>
    <% if embed_id.present? %>
      <div data-controller="reveal" data-reveal-direction="scale">
        <div class="elfsight-app-<%= embed_id %>" data-elfsight-app-lazy></div>
      </div>
    <% elsif @posts.any? %>
      <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">
        <% @posts.each_with_index do |post, idx| %>
          <a href="<%= post.instagram_url %>" target="_blank" rel="noopener noreferrer"
             class="group relative aspect-square overflow-hidden" style="border-radius:12px"
             data-controller="reveal" data-reveal-direction="scale" data-reveal-delay="<%= idx * 100 %>">
            <% if post.photo.attached? %>
              <%= image_tag post.photo.variant(resize_to_fill: [400, 400]), class: "w-full h-full object-cover transition-transform duration-700 group-hover:scale-105", alt: post.caption&.truncate(80) %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center" style="background:var(--color-blush-soft)">
                <svg class="w-10 h-10" style="color:rgba(217,92,132,0.25)" fill="none" stroke="currentColor" stroke-width="1" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/></svg>
              </div>
            <% end %>
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-5" style="background:linear-gradient(to top, rgba(172,97,103,0.92), transparent)">
              <p class="font-body line-clamp-3" style="font-size:13px;color:#fff"><%= post.caption&.truncate(100) %></p>
            </div>
          </a>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-20">
        <p class="font-body" style="font-size:15px;color:var(--color-taupe)">Les publications arrivent bientôt...</p>
      </div>
    <% end %>

    <div class="text-center mt-14" data-controller="reveal">
      <a href="<%= c("instagram_url") %>" target="_blank" rel="noopener noreferrer" class="btn-primary btn-lg font-accent gap-3">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        Suivre sur Instagram
      </a>
    </div>
  </div>
</section>

<%# ═══════════════════════════════ TÉMOIGNAGES ═══════════════════════════════ %>
<% if @testimonials.any? %>
<section id="temoignages" class="section-py" style="background:var(--color-paper)">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="text-center mb-16 lg:mb-20" data-controller="reveal" data-reveal-direction="up">
      <p class="eyebrow eyebrow-c">Témoignages</p>
    </div>

    <% tcount = @testimonials.size %>
    <% grid_cls = tcount == 1 ? "max-w-2xl mx-auto" : (tcount == 2 ? "grid md:grid-cols-2 gap-8 max-w-4xl mx-auto" : "grid md:grid-cols-3 gap-8") %>
    <div class="<%= grid_cls %>">
      <% @testimonials.each_with_index do |testimonial, idx| %>
        <div class="card-glass p-10 relative" data-controller="reveal" data-reveal-direction="up" data-reveal-delay="<%= idx * 150 %>">
          <svg class="w-10 h-10 mb-6" style="color:var(--color-blush)" fill="currentColor" viewBox="0 0 24 24"><path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/></svg>
          <p class="font-body mb-8" style="font-size:15px;line-height:1.85;color:var(--color-ink)"><%= testimonial.quote %></p>
          <div style="width:36px;height:2px;background:var(--color-primary);margin-bottom:16px"></div>
          <p class="font-display" style="font-size:16px;font-weight:700;text-transform:uppercase;letter-spacing:-0.01em;color:var(--color-ink)"><%= testimonial.name %></p>
          <p class="font-body" style="font-size:12px;color:var(--color-taupe);letter-spacing:0.5px"><%= testimonial.role %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>

<%= render "shared/footer" %>
