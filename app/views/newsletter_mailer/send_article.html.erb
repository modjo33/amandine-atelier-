<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0;padding:0;background:#f6f1e8;font-family:Helvetica Neue,Helvetica,Arial,sans-serif">
  <div style="max-width:600px;margin:0 auto;padding:40px 24px">

    <%# Header %>
    <div style="text-align:center;padding-bottom:32px;border-bottom:1px solid rgba(74,63,56,0.12)">
      <p style="font-size:14px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:#4A3F38;margin:0">Amandine Atelier Digital</p>
    </div>

    <%# Content %>
    <div style="padding:40px 0">
      <p style="font-size:14px;color:rgba(74,63,56,0.50);margin:0 0 8px">Nouvel article</p>
      <h1 style="font-size:28px;font-weight:400;color:#4A3F38;margin:0 0 20px;line-height:1.3"><%= @article.title %></h1>

      <% if @article.excerpt.present? %>
        <p style="font-size:16px;color:rgba(74,63,56,0.65);line-height:1.8;margin:0 0 24px"><%= @article.excerpt %></p>
      <% end %>

      <% if @article.cover_image.attached? %>
        <div style="margin:0 0 24px">
          <%= image_tag url_for(@article.cover_image), style: "width:100%;max-height:300px;object-fit:cover;border-radius:12px" %>
        </div>
      <% end %>

      <p style="font-size:15px;color:rgba(74,63,56,0.70);line-height:1.9;margin:0 0 32px"><%= truncate(strip_tags(@article.content), length: 400) %></p>

      <div style="text-align:center">
        <a href="<%= article_url(slug: @article.slug) %>" style="display:inline-block;padding:16px 40px;background:#4A3F38;color:#f6f1e8;border-radius:50px;text-decoration:none;font-size:15px;letter-spacing:0.5px">Lire l'article</a>
      </div>
    </div>

    <%# Footer %>
    <div style="padding-top:32px;border-top:1px solid rgba(74,63,56,0.12);text-align:center">
      <p style="font-size:12px;color:rgba(74,63,56,0.35);margin:0 0 8px">Vous recevez cet email car vous avez accepté de recevoir la newsletter.</p>
      <a href="<%= @unsubscribe_url %>" style="font-size:12px;color:rgba(74,63,56,0.45);text-decoration:underline">Se désinscrire</a>
    </div>
  </div>
</body>
</html>
