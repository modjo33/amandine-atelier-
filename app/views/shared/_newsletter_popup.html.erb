<div data-controller="newsletter-popup"
     data-newsletter-popup-delay-value="3000"
     data-action="keydown.esc@document->newsletter-popup#closeOnEscape"
     class="hidden fixed inset-0 z-50">

  <%# Backdrop %>
  <div data-newsletter-popup-target="overlay"
       data-action="click->newsletter-popup#closeOnBackground"
       class="absolute inset-0 bg-black/50 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 transition-opacity duration-300">

    <%# Modal %>
    <div class="relative bg-light rounded-2xl shadow-2xl max-w-md w-full overflow-hidden">

      <%# Close button %>
      <button data-action="newsletter-popup#close" type="button"
              class="absolute top-3 right-3 z-10 w-8 h-8 flex items-center justify-center rounded-full hover:bg-dark/10 transition-colors text-dark/40 hover:text-dark">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

      <%# Form view %>
      <div data-newsletter-popup-target="formWrapper" class="p-8 text-center">
        <p class="text-4xl mb-4">&#127873;</p>
        <h3 class="font-body text-2xl text-dark font-semibold mb-2">Un cadeau pour toi</h3>
        <p class="font-body text-dark/70 text-sm leading-relaxed mb-6">
          Re&ccedil;ois ma vid&eacute;o gratuite&nbsp;: attire les bonnes personnes
          sur les r&eacute;seaux sans y passer ta vie
        </p>

        <p data-newsletter-popup-target="errorMessage"
           class="hidden text-dark text-sm font-body text-center mb-4 bg-dark/10 rounded-lg px-4 py-2"></p>

        <form data-newsletter-popup-target="formElement"
              action="<%= subscribers_path %>"
              method="post"
              data-action="submit->newsletter-popup#submit"
              class="space-y-3">
          <input data-newsletter-popup-target="firstName"
                 type="text" name="subscriber[first_name]" required
                 placeholder="Ton pr&eacute;nom"
                 class="w-full px-4 py-3 rounded-lg border border-dark/12 bg-accent/20 font-body text-dark placeholder-dark/35 focus:outline-none focus:ring-2 focus:ring-dark/20 transition-colors">
          <input data-newsletter-popup-target="email"
                 type="email" name="subscriber[email]" required
                 placeholder="Ton adresse email"
                 class="w-full px-4 py-3 rounded-lg border border-dark/12 bg-accent/20 font-body text-dark placeholder-dark/35 focus:outline-none focus:ring-2 focus:ring-dark/20 transition-colors">
          <button data-newsletter-popup-target="submitBtn" type="submit"
                  class="w-full px-6 py-3 bg-dark text-accent font-body font-medium rounded-lg hover:bg-dark-hover transition-colors duration-300 cursor-pointer">
            Je re&ccedil;ois ma vid&eacute;o &rarr;
          </button>
        </form>

        <button data-action="newsletter-popup#close" type="button"
                class="mt-3 font-body text-dark/40 text-xs hover:text-dark/60 transition-colors">
          Non merci
        </button>
      </div>

      <%# Success view %>
      <div data-newsletter-popup-target="success" class="hidden p-8 text-center">
        <div class="w-16 h-16 bg-muted/15 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
          </svg>
        </div>
        <h4 class="font-body text-2xl text-dark font-semibold mb-2">C'est dans ta bo&icirc;te mail !</h4>
        <p class="font-body text-dark/60 text-sm mb-4">
          V&eacute;rifie tes spams si tu ne la vois pas.
        </p>
        <button data-action="newsletter-popup#close" type="button"
                class="px-6 py-2 text-dark font-body font-medium text-sm hover:text-dark/70 transition-colors">
          Fermer
        </button>
      </div>

    </div>
  </div>
</div>
