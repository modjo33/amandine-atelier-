<%# Navbar partagée — local var `active` : "accueil" | "blog" (pour l'état actif du lien Blog) %>
<% active ||= "accueil" %>
<nav data-controller="navbar" class="fixed top-0 inset-x-0 z-40" style="height:70px;border-bottom:1px solid rgba(246,241,232,0.08);transition:background 0.4s ease, box-shadow 0.4s ease, backdrop-filter 0.4s ease">
  <div class="max-w-[1200px] mx-auto px-6 lg:px-10 flex items-center justify-between h-full">
    <a href="/" class="font-body text-light" style="font-size:15px;font-weight:500;letter-spacing:2px;text-transform:uppercase">Amandine Atelier Digital</a>

    <%# Desktop menu %>
    <div class="hidden md:flex items-center gap-14">
      <a href="/#hero" class="font-body uppercase hover:text-accent transition-colors duration-300" style="font-size:11px;font-weight:400;letter-spacing:3px;color:rgba(246,241,232,0.55)">Accueil</a>
      <a href="/#solution" class="font-body uppercase hover:text-accent transition-colors duration-300" style="font-size:11px;font-weight:400;letter-spacing:3px;color:rgba(246,241,232,0.55)">À propos</a>
      <a href="/#offres" class="font-body uppercase hover:text-accent transition-colors duration-300" style="font-size:11px;font-weight:400;letter-spacing:3px;color:rgba(246,241,232,0.55)">Offres</a>
      <a href="/blog" class="font-body uppercase <%= active == "blog" ? "text-accent" : "hover:text-accent transition-colors duration-300" %>" style="font-size:11px;font-weight:400;letter-spacing:3px;<%= "color:rgba(246,241,232,0.55)" unless active == "blog" %>">Blog</a>
      <button type="button" data-controller="contact-modal" data-action="click->contact-modal#open" class="btn-primary font-body uppercase" style="font-size:11px;letter-spacing:3px;padding:10px 28px">Contact</button>
      <div class="flex items-center gap-3">
        <a href="<%= c("instagram_url") %>" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity duration-300">
          <svg class="w-5 h-5" fill="#fcdfb5" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/amandine-monte-6583341a7" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity duration-300">
          <svg class="w-5 h-5" fill="#fcdfb5" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>
    </div>

    <%# Burger mobile %>
    <button class="md:hidden flex flex-col gap-1.5 p-2" data-navbar-target="burger" data-action="click->navbar#toggleMenu">
      <span class="burger-line"></span>
      <span class="burger-line"></span>
      <span class="burger-line"></span>
    </button>
  </div>

  <%# Mobile menu %>
  <div data-navbar-target="menu" class="mobile-menu md:hidden">
    <a href="/#hero" class="font-body uppercase py-3 hover:text-accent transition-colors" style="font-size:12px;letter-spacing:3px;color:rgba(246,241,232,0.60)">Accueil</a>
    <a href="/#solution" class="font-body uppercase py-3 hover:text-accent transition-colors" style="font-size:12px;letter-spacing:3px;color:rgba(246,241,232,0.60)">À propos</a>
    <a href="/#offres" class="font-body uppercase py-3 hover:text-accent transition-colors" style="font-size:12px;letter-spacing:3px;color:rgba(246,241,232,0.60)">Offres</a>
    <a href="/blog" class="font-body uppercase py-3 <%= active == "blog" ? "text-accent" : "hover:text-accent transition-colors" %>" style="font-size:12px;letter-spacing:3px;<%= "color:rgba(246,241,232,0.60)" unless active == "blog" %>">Blog</a>
    <button type="button" data-controller="contact-modal" data-action="click->contact-modal#open" class="btn-primary font-body uppercase mt-3 text-center" style="font-size:12px;letter-spacing:3px;padding:12px 28px">Contact</button>
    <div class="flex items-center justify-center gap-6 mt-4 pt-4" style="border-top:1px solid rgba(246,241,232,0.10)">
      <a href="<%= c("instagram_url") %>" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors" style="color:rgba(246,241,232,0.55)">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
      <a href="https://www.linkedin.com/in/amandine-monte-6583341a7" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors" style="color:rgba(246,241,232,0.55)">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
    </div>
  </div>
</nav>
