<div class="mb-10">
  <h1 class="font-display text-light" style="font-size:clamp(28px,3vw,38px);font-weight:400">Dashboard</h1>
  <p class="font-body mt-2" style="font-size:14px;color:rgba(246,241,232,0.45)">Bienvenue dans ton espace d'administration.</p>
</div>

<%# ── Analytics ── %>
<div class="mb-10">
  <h2 class="font-body text-light mb-5" style="font-size:18px;font-weight:500">Statistiques de visite</h2>
  <div class="grid grid-cols-2 lg:grid-cols-5 gap-5 mb-8">
    <div class="admin-stat-card">
      <p class="admin-stat-number"><%= @views_today %></p>
      <p class="admin-stat-label">Vues aujourd'hui</p>
    </div>
    <div class="admin-stat-card">
      <p class="admin-stat-number"><%= @unique_visitors_today %></p>
      <p class="admin-stat-label">Visiteurs uniques</p>
    </div>
    <div class="admin-stat-card">
      <p class="admin-stat-number"><%= @views_week %></p>
      <p class="admin-stat-label">Vues cette semaine</p>
    </div>
    <div class="admin-stat-card">
      <p class="admin-stat-number"><%= @views_month %></p>
      <p class="admin-stat-label">Vues ce mois</p>
    </div>
    <div class="admin-stat-card">
      <p class="admin-stat-number"><%= @conversion_rate %>%</p>
      <p class="admin-stat-label">Taux conversion</p>
    </div>
  </div>

  <%# Mini chart - last 7 days %>
  <div class="rounded-2xl p-6" style="background:rgba(246,241,232,0.04);border:1px solid rgba(246,241,232,0.08)">
    <p class="font-body mb-4" style="font-size:13px;color:rgba(246,241,232,0.40)">Visites — 7 derniers jours</p>
    <div class="flex items-end gap-3" style="height:120px">
      <% max_views = [@chart_data.map { |d| d[:views] }.max, 1].max %>
      <% @chart_data.each do |day| %>
        <div class="flex-1 flex flex-col items-center gap-2">
          <span class="font-body" style="font-size:11px;color:rgba(246,241,232,0.50)"><%= day[:views] %></span>
          <div class="w-full rounded-t-lg transition-all" style="height:<%= [(day[:views].to_f / max_views * 80).round, 4].max %>px;background:linear-gradient(to top, rgba(252,223,181,0.40), rgba(252,223,181,0.15))"></div>
          <span class="font-body" style="font-size:10px;color:rgba(246,241,232,0.30)"><%= day[:label] %></span>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# ── Stats cards ── %>
<div class="grid grid-cols-2 lg:grid-cols-5 gap-5 mb-14">
  <div class="admin-stat-card">
    <p class="admin-stat-number"><%= @contents_count %></p>
    <p class="admin-stat-label">Contenus</p>
  </div>
  <div class="admin-stat-card">
    <p class="admin-stat-number"><%= @sections_count %></p>
    <p class="admin-stat-label">Sections</p>
  </div>
  <div class="admin-stat-card">
    <p class="admin-stat-number"><%= @active_posts_count %>/<%= @posts_count %></p>
    <p class="admin-stat-label">Posts actifs</p>
  </div>
  <div class="admin-stat-card">
    <p class="admin-stat-number"><%= @subscribers_count %></p>
    <p class="admin-stat-label">Abonnés</p>
  </div>
  <div class="admin-stat-card">
    <p class="admin-stat-number"><%= @active_testimonials_count %>/<%= @testimonials_count %></p>
    <p class="admin-stat-label">Témoignages</p>
  </div>
</div>

<%# ── Quick actions ── %>
<div class="mb-10">
  <h2 class="font-body text-light mb-6" style="font-size:18px;font-weight:500">Accès rapide</h2>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
    <%= link_to admin_site_contents_path, class: "admin-quick-card group" do %>
      <div class="flex items-center gap-4">
        <div class="admin-quick-icon">✏️</div>
        <div>
          <p class="font-body text-light" style="font-size:15px;font-weight:500">Modifier le contenu</p>
          <p class="font-body" style="font-size:13px;color:rgba(246,241,232,0.40)">Textes et images du site</p>
        </div>
      </div>
    <% end %>

    <%= link_to admin_posts_path, class: "admin-quick-card group" do %>
      <div class="flex items-center gap-4">
        <div class="admin-quick-icon">📸</div>
        <div>
          <p class="font-body text-light" style="font-size:15px;font-weight:500">Posts Instagram</p>
          <p class="font-body" style="font-size:13px;color:rgba(246,241,232,0.40)">Gérer le feed affiché</p>
        </div>
      </div>
    <% end %>

    <%= link_to admin_subscribers_path, class: "admin-quick-card group" do %>
      <div class="flex items-center gap-4">
        <div class="admin-quick-icon">👥</div>
        <div>
          <p class="font-body text-light" style="font-size:15px;font-weight:500">Abonnés newsletter</p>
          <p class="font-body" style="font-size:13px;color:rgba(246,241,232,0.40)">Voir la liste</p>
        </div>
      </div>
    <% end %>

    <%= link_to admin_testimonials_path, class: "admin-quick-card group" do %>
      <div class="flex items-center gap-4">
        <div class="admin-quick-icon">💬</div>
        <div>
          <p class="font-body text-light" style="font-size:15px;font-weight:500">Témoignages</p>
          <p class="font-body" style="font-size:13px;color:rgba(246,241,232,0.40)">Gérer les avis clients</p>
        </div>
      </div>
    <% end %>

    <%= link_to root_path, target: "_blank", class: "admin-quick-card group" do %>
      <div class="flex items-center gap-4">
        <div class="admin-quick-icon">👁️</div>
        <div>
          <p class="font-body text-light" style="font-size:15px;font-weight:500">Aperçu du site</p>
          <p class="font-body" style="font-size:13px;color:rgba(246,241,232,0.40)">Ouvrir dans un nouvel onglet</p>
        </div>
      </div>
    <% end %>

    <%= link_to export_csv_admin_subscribers_path, class: "admin-quick-card group" do %>
      <div class="flex items-center gap-4">
        <div class="admin-quick-icon">📥</div>
        <div>
          <p class="font-body text-light" style="font-size:15px;font-weight:500">Exporter les abonnés</p>
          <p class="font-body" style="font-size:13px;color:rgba(246,241,232,0.40)">Télécharger en CSV</p>
        </div>
      </div>
    <% end %>
  </div>
</div>
