<div class="mb-10">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="font-display text-light" style="font-size:clamp(28px,3vw,38px);font-weight:400">Posts Instagram</h1>
      <p class="font-body mt-2" style="font-size:14px;color:rgba(246,241,232,0.45)"><%= @posts.count %> post<%= "s" if @posts.count > 1 %></p>
    </div>
    <%= link_to new_admin_post_path, class: "btn-primary font-body", style: "padding:12px 28px;font-size:14px" do %>
      + Nouveau post
    <% end %>
  </div>
</div>

<% if @posts.any? %>
  <div class="overflow-x-auto rounded-2xl" style="background:rgba(246,241,232,0.04);border:1px solid rgba(246,241,232,0.08)">
    <table class="w-full">
      <thead>
        <tr style="border-bottom:1px solid rgba(246,241,232,0.08)">
          <th class="px-5 py-3 text-left font-body font-medium text-xs uppercase tracking-wider" style="color:rgba(246,241,232,0.35)">Photo</th>
          <th class="px-5 py-3 text-left font-body font-medium text-xs uppercase tracking-wider" style="color:rgba(246,241,232,0.35)">Caption</th>
          <th class="px-5 py-3 text-center font-body font-medium text-xs uppercase tracking-wider" style="color:rgba(246,241,232,0.35)">Pos.</th>
          <th class="px-5 py-3 text-center font-body font-medium text-xs uppercase tracking-wider" style="color:rgba(246,241,232,0.35)">Actif</th>
          <th class="px-5 py-3 text-right font-body font-medium text-xs uppercase tracking-wider" style="color:rgba(246,241,232,0.35)">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @posts.each do |post| %>
          <tr class="transition-colors" style="border-bottom:1px solid rgba(246,241,232,0.05)" onmouseenter="this.style.background='rgba(246,241,232,0.04)'" onmouseleave="this.style.background='transparent'">
            <td class="px-5 py-3">
              <% if post.photo.attached? %>
                <%= image_tag post.photo.variant(resize_to_fill: [80, 80]), class: "w-14 h-14 object-cover rounded-lg" %>
              <% else %>
                <div class="w-14 h-14 rounded-lg flex items-center justify-center" style="background:rgba(246,241,232,0.06)">
                  <svg class="w-6 h-6" style="color:rgba(246,241,232,0.15)" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0022.5 18.75V5.25A2.25 2.25 0 0020.25 3H3.75A2.25 2.25 0 001.5 5.25v13.5A2.25 2.25 0 003.75 21z"/>
                  </svg>
                </div>
              <% end %>
            </td>
            <td class="px-5 py-3">
              <p class="font-body text-light text-sm line-clamp-2" style="opacity:0.75"><%= post.caption&.truncate(80) %></p>
            </td>
            <td class="px-5 py-3 text-center">
              <span class="font-body text-sm" style="color:rgba(246,241,232,0.50)"><%= post.position %></span>
            </td>
            <td class="px-5 py-3 text-center">
              <% if post.active? %>
                <span class="inline-block w-3 h-3 rounded-full" style="background:#86efac"></span>
              <% else %>
                <span class="inline-block w-3 h-3 rounded-full" style="background:rgba(246,241,232,0.15)"></span>
              <% end %>
            </td>
            <td class="px-5 py-3 text-right">
              <div class="flex items-center justify-end gap-2">
                <%= link_to edit_admin_post_path(post), class: "p-2 transition-colors", style: "color:rgba(246,241,232,0.35)" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125"/>
                  </svg>
                <% end %>
                <%= button_to admin_post_path(post), method: :delete,
                    data: { turbo_confirm: "Supprimer ce post ?" },
                    class: "p-2 transition-colors", style: "color:rgba(246,241,232,0.35)" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0"/>
                  </svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="text-center py-16 rounded-2xl" style="background:rgba(246,241,232,0.04);border:1px solid rgba(246,241,232,0.08)">
    <p class="font-body mb-4" style="color:rgba(246,241,232,0.35)">Aucun post pour le moment.</p>
    <%= link_to "Créer le premier post", new_admin_post_path, class: "font-body text-accent hover:opacity-70 transition-opacity" %>
  </div>
<% end %>
