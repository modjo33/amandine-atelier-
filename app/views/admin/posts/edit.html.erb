<div class="mb-10">
  <%= link_to admin_posts_path, class: "inline-flex items-center gap-1 font-body hover:text-accent transition-colors mb-3", style: "font-size:13px;color:rgba(246,241,232,0.40)" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
    Retour
  <% end %>
  <h1 class="font-display text-light" style="font-size:clamp(28px,3vw,38px);font-weight:400">Modifier le post</h1>
</div>

<div class="max-w-2xl">
  <%= render "form", post: @post %>
</div>
