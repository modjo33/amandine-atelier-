<%= form_with model: [:admin, post], class: "space-y-6", multipart: true do |f| %>
  <% if post.errors.any? %>
    <div class="rounded-xl p-4" style="background:rgba(252,165,165,0.10);border:1px solid rgba(252,165,165,0.20)">
      <p class="font-body font-medium mb-2" style="color:#fca5a5"><%= pluralize(post.errors.count, "erreur") %> :</p>
      <ul class="list-disc list-inside text-sm font-body" style="color:rgba(252,165,165,0.80)">
        <% post.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="admin-field-card">
    <label class="admin-field-label">Photo</label>
    <% if post.photo.attached? %>
      <div class="mb-4">
        <%= image_tag post.photo.variant(resize_to_limit: [200, 200]), class: "w-32 h-32 object-cover rounded-xl" %>
      </div>
    <% end %>
    <%= f.file_field :photo, accept: "image/*", class: "admin-input-file" %>
  </div>

  <div class="admin-field-card">
    <label class="admin-field-label">Caption</label>
    <%= f.text_area :caption, rows: 4, class: "admin-input-textarea", placeholder: "Description du post..." %>
  </div>

  <div class="admin-field-card">
    <label class="admin-field-label">URL Instagram</label>
    <%= f.text_field :instagram_url, class: "admin-input-text", placeholder: "https://instagram.com/p/..." %>
  </div>

  <div class="grid grid-cols-2 gap-5">
    <div class="admin-field-card">
      <label class="admin-field-label">Position</label>
      <%= f.number_field :position, min: 0, class: "admin-input-text" %>
    </div>
    <div class="admin-field-card flex items-center gap-3">
      <%= f.check_box :active, class: "w-5 h-5 rounded accent-accent" %>
      <label class="font-body text-light" style="font-size:14px">Actif</label>
    </div>
  </div>

  <div class="flex items-center gap-4 pt-2">
    <%= f.submit post.persisted? ? "Mettre à jour" : "Créer le post",
        class: "btn-primary font-body cursor-pointer", style: "padding:14px 36px;font-size:15px" %>
    <%= link_to "Annuler", admin_posts_path, class: "font-body hover:text-accent transition-colors", style: "font-size:14px;color:rgba(246,241,232,0.40)" %>
  </div>
<% end %>
