<%= form_with model: [:admin, article], class: "space-y-6" do |f| %>
  <% if article.errors.any? %>
    <div class="px-5 py-3 rounded-xl mb-4" style="background:rgba(252,165,165,0.10);border:1px solid rgba(252,165,165,0.20);color:#fca5a5;font-size:14px">
      <% article.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="admin-field-card">
    <label class="admin-field-label">Titre de l'article</label>
    <%= f.text_field :title, class: "admin-input-text", placeholder: "Comment booster ta visibilité sur Instagram" %>
  </div>

  <div class="grid sm:grid-cols-2 gap-6">
    <div class="admin-field-card">
      <label class="admin-field-label">Slug (URL)</label>
      <%= f.text_field :slug, class: "admin-input-text", placeholder: "Généré automatiquement si vide" %>
      <p class="font-body mt-2" style="font-size:12px;color:rgba(246,241,232,0.30)">Laisser vide pour générer depuis le titre</p>
    </div>
    <div class="admin-field-card">
      <label class="admin-field-label">Catégorie</label>
      <%= f.text_field :category, class: "admin-input-text", placeholder: "Stratégie, Réseaux sociaux, Organisation..." %>
    </div>
  </div>

  <div class="admin-field-card">
    <label class="admin-field-label">Extrait (affiché sur la liste du blog)</label>
    <%= f.text_area :excerpt, rows: 3, class: "admin-input-textarea", placeholder: "Un résumé court et accrocheur de l'article..." %>
  </div>

  <div class="admin-field-card">
    <label class="admin-field-label">Contenu de l'article</label>
    <%= f.text_area :content, rows: 15, class: "admin-input-textarea", placeholder: "Écris ton article ici... Tu peux utiliser des paragraphes avec des lignes vides." %>
    <p class="font-body mt-2" style="font-size:12px;color:rgba(246,241,232,0.30)">Sépare les paragraphes avec une ligne vide. Utilise **texte** pour le gras et *texte* pour l'italique.</p>
  </div>

  <div class="admin-field-card">
    <label class="admin-field-label">Image de couverture</label>
    <% if article.cover_image.attached? %>
      <div class="mb-4">
        <%= image_tag article.cover_image.variant(resize_to_limit: [400, 250]), class: "rounded-lg", style: "max-height:180px" %>
      </div>
    <% end %>
    <%= f.file_field :cover_image, accept: "image/*", class: "admin-input-file" %>
    <p class="font-body mt-2" style="font-size:12px;color:rgba(246,241,232,0.30)">Format recommandé : 1200x630px (ratio réseaux sociaux)</p>
  </div>

  <div class="admin-field-card">
    <label class="admin-field-label">Meta description (SEO)</label>
    <%= f.text_area :meta_description, rows: 2, class: "admin-input-textarea", placeholder: "Description pour Google (max 160 caractères)", maxlength: 160 %>
    <p class="font-body mt-2" style="font-size:12px;color:rgba(246,241,232,0.30)">Apparaît dans les résultats Google. Idéalement 120-160 caractères.</p>
  </div>

  <div class="grid sm:grid-cols-2 gap-6">
    <div class="admin-field-card">
      <label class="admin-field-label">Publier</label>
      <div class="flex items-center gap-3 mt-2">
        <%= f.check_box :published, class: "w-5 h-5 rounded", style: "accent-color:#fcdfb5" %>
        <span class="font-body" style="font-size:14px;color:rgba(246,241,232,0.60)">Article visible sur le blog</span>
      </div>
    </div>
    <div class="admin-field-card">
      <label class="admin-field-label">Date de publication</label>
      <%= f.datetime_local_field :published_at, class: "admin-input-text" %>
      <p class="font-body mt-2" style="font-size:12px;color:rgba(246,241,232,0.30)">Laisser vide = publié immédiatement</p>
    </div>
  </div>

  <div class="flex items-center gap-4 pt-4">
    <%= f.submit "Enregistrer", class: "btn-primary font-body cursor-pointer", style: "padding:14px 40px;font-size:15px;letter-spacing:0.5px" %>
    <%= link_to "Annuler", admin_articles_path, class: "font-body hover:text-accent transition-colors", style: "font-size:14px;color:rgba(246,241,232,0.40)" %>
  </div>
<% end %>
