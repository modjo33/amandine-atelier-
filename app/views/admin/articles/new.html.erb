<div class="mb-10">
  <div class="flex items-center gap-3 mb-2">
    <%= link_to admin_articles_path, class: "inline-flex items-center gap-1 font-body hover:text-accent transition-colors", style: "font-size:13px;color:rgba(246,241,232,0.40)" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
      Retour
    <% end %>
  </div>
  <h1 class="font-display text-light" style="font-size:clamp(26px,3vw,34px);font-weight:400">Nouvel article</h1>
</div>

<%= render "form", article: @article %>
