<div class="mb-10 flex items-center justify-between flex-wrap gap-4">
  <div>
    <h1 class="font-display text-light" style="font-size:clamp(28px,3vw,38px);font-weight:400">Blog</h1>
    <p class="font-body mt-2" style="font-size:14px;color:rgba(246,241,232,0.45)"><%= @articles.count %> article<%= "s" if @articles.count > 1 %></p>
  </div>
  <%= link_to new_admin_article_path, class: "btn-primary font-body", style: "padding:12px 28px;font-size:14px" do %>
    + Nouvel article
  <% end %>
</div>

<% if @articles.any? %>
  <div class="space-y-4">
    <% @articles.each do |article| %>
      <div class="admin-field-card flex items-start gap-5">
        <% if article.cover_image.attached? %>
          <div class="shrink-0 rounded-lg overflow-hidden" style="width:80px;height:60px">
            <%= image_tag article.cover_image.variant(resize_to_fill: [160, 120]), class: "w-full h-full object-cover" %>
          </div>
        <% end %>
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-3 mb-1">
            <p class="font-body text-light" style="font-size:16px;font-weight:500"><%= article.title %></p>
            <% if article.published? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-body" style="background:rgba(134,239,172,0.12);color:#86efac">Publié</span>
            <% else %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-body" style="background:rgba(252,223,181,0.12);color:#fcdfb5">Brouillon</span>
            <% end %>
          </div>
          <p class="font-body" style="font-size:13px;color:rgba(246,241,232,0.45)">
            <%= article.category.present? ? article.category : "Sans catégorie" %>
            <% if article.published_at %> · <%= article.published_at.strftime("%d/%m/%Y") %><% end %>
            · <%= article.reading_time %> min de lecture
          </p>
          <% if article.excerpt.present? %>
            <p class="font-body mt-1" style="font-size:13px;color:rgba(246,241,232,0.35)"><%= article.excerpt.truncate(120) %></p>
          <% end %>
          <p class="font-body mt-1" style="font-size:11px;color:rgba(246,241,232,0.25)">/<%= article.slug %></p>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <% if article.published? %>
            <%= link_to send_newsletter_admin_article_path(article), data: { turbo_method: :post, turbo_confirm: "Envoyer cet article à #{Contact.newsletter_subscribers.count} contact(s) ?" }, class: "admin-btn-sm", title: "Envoyer newsletter", style: "color:#86efac" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12 3.269 3.125A59.769 59.769 0 0 1 21.485 12 59.768 59.768 0 0 1 3.27 20.875L5.999 12Zm0 0h7.5"/></svg>
            <% end %>
            <%= link_to article_path(slug: article.slug), target: "_blank", class: "admin-btn-sm", title: "Voir" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
            <% end %>
          <% end %>
          <%= link_to edit_admin_article_path(article), class: "admin-btn-sm" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Z"/></svg>
          <% end %>
          <%= link_to admin_article_path(article), data: { turbo_method: :delete, turbo_confirm: "Supprimer cet article ?" }, class: "admin-btn-sm admin-btn-danger" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/></svg>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-16 rounded-2xl" style="background:rgba(246,241,232,0.04);border:1px solid rgba(246,241,232,0.08)">
    <p class="font-body mb-4" style="color:rgba(246,241,232,0.35)">Aucun article pour le moment.</p>
    <%= link_to "Écrire le premier", new_admin_article_path, class: "btn-primary font-body", style: "padding:12px 28px;font-size:14px" %>
  </div>
<% end %>
