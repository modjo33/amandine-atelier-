<%= form_with model: [:admin, testimonial], class: "space-y-6" do |f| %>
  <% if testimonial.errors.any? %>
    <div class="px-5 py-3 rounded-xl mb-4" style="background:rgba(252,165,165,0.10);border:1px solid rgba(252,165,165,0.20);color:#fca5a5;font-size:14px">
      <% testimonial.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="admin-field-card">
    <label class="admin-field-label">Citation</label>
    <%= f.text_area :quote, rows: 4, class: "admin-input-textarea", placeholder: "Le témoignage du client…" %>
  </div>

  <div class="grid sm:grid-cols-2 gap-6">
    <div class="admin-field-card">
      <label class="admin-field-label">Nom</label>
      <%= f.text_field :name, class: "admin-input-text", placeholder: "Marie D." %>
    </div>
    <div class="admin-field-card">
      <label class="admin-field-label">Rôle / Poste</label>
      <%= f.text_field :role, class: "admin-input-text", placeholder: "Fondatrice, Boutique Élise" %>
    </div>
  </div>

  <div class="grid sm:grid-cols-2 gap-6">
    <div class="admin-field-card">
      <label class="admin-field-label">Position (ordre d'affichage)</label>
      <%= f.number_field :position, class: "admin-input-text", min: 0 %>
    </div>
    <div class="admin-field-card">
      <label class="admin-field-label">Visible sur le site</label>
      <div class="flex items-center gap-3 mt-2">
        <%= f.check_box :active, class: "w-5 h-5 rounded", style: "accent-color:#fcdfb5" %>
        <span class="font-body" style="font-size:14px;color:rgba(246,241,232,0.60)">Afficher ce témoignage</span>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-4 pt-4">
    <%= f.submit "Enregistrer", class: "btn-primary font-body cursor-pointer", style: "padding:14px 40px;font-size:15px;letter-spacing:0.5px" %>
    <%= link_to "Annuler", admin_testimonials_path, class: "font-body hover:text-accent transition-colors", style: "font-size:14px;color:rgba(246,241,232,0.40)" %>
  </div>
<% end %>
