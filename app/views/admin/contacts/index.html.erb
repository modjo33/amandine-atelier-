<div class="flex items-center justify-between mb-10">
  <h1 class="font-display text-light" style="font-size:clamp(26px,3vw,34px);font-weight:400">Messages reçus</h1>
  <span class="font-body" style="font-size:14px;color:rgba(246,241,232,0.40)"><%= @contacts.count %> message<%= @contacts.count > 1 ? "s" : "" %></span>
</div>

<% if @contacts.any? %>
  <div class="space-y-4">
    <% @contacts.each do |contact| %>
      <div class="card-glass" style="border-radius:14px;padding:20px 24px">
        <div class="flex items-start justify-between gap-4">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 mb-2">
              <span class="font-body text-light" style="font-size:15px;font-weight:500"><%= contact.first_name %> <%= contact.last_name %></span>
              <% if contact.newsletter_opt_in? %>
                <span class="font-body px-2 py-0.5 rounded-full" style="font-size:10px;background:rgba(134,239,172,0.12);color:#86efac">Newsletter</span>
              <% end %>
              <span class="font-body" style="font-size:12px;color:rgba(246,241,232,0.30)"><%= contact.created_at.strftime("%d/%m/%Y à %H:%M") %></span>
            </div>
            <div class="flex items-center gap-4 mb-2">
              <span class="font-body" style="font-size:13px;color:rgba(246,241,232,0.50)"><%= contact.email %></span>
              <% if contact.phone.present? %>
                <span class="font-body" style="font-size:13px;color:rgba(246,241,232,0.50)"><%= contact.phone %></span>
              <% end %>
            </div>
            <% if contact.message.present? %>
              <p class="font-body" style="font-size:14px;color:rgba(246,241,232,0.60);line-height:1.7"><%= truncate(contact.message, length: 200) %></p>
            <% end %>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <%= link_to admin_contact_path(contact), class: "admin-btn-sm" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
            <% end %>
            <%= link_to admin_contact_path(contact), data: { turbo_method: :delete, turbo_confirm: "Supprimer ce message ?" }, class: "admin-btn-danger" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0"/></svg>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-20">
    <p class="font-body" style="font-size:16px;color:rgba(246,241,232,0.35)">Aucun message pour le moment.</p>
  </div>
<% end %>
