<%= content_for :head do %>
  <meta name="description" content="Blog Amandine Atelier Digital - Conseils en stratégie digitale, réseaux sociaux et organisation.">
  <title>Blog — Amandine Atelier Digital</title>
<% end %>

<%= render "shared/navbar", active: "blog" %>

<section style="background:var(--color-paper);padding-top:130px;padding-bottom:100px">
  <div class="max-w-[900px] mx-auto px-6">
    <div class="text-center mb-16" data-controller="reveal" data-reveal-direction="scale">
      <p class="eyebrow eyebrow-c">Blog</p>
    </div>

    <% if @categories.any? %>
      <div class="flex flex-wrap justify-center gap-3 mb-14">
        <%= link_to "Tous", blog_path, class: "font-accent px-4 py-2 rounded-full transition-all", style: "font-size:13px;font-weight:600;#{params[:category].blank? ? 'background:var(--color-primary);color:#fff;border:1px solid var(--color-primary)' : 'background:#fff;color:var(--color-ink-soft);border:1px solid rgba(150,129,107,0.20)'}" %>
        <% @categories.each do |cat| %>
          <%= link_to cat, blog_path(category: cat), class: "font-accent px-4 py-2 rounded-full transition-all", style: "font-size:13px;font-weight:600;#{params[:category] == cat ? 'background:var(--color-primary);color:#fff;border:1px solid var(--color-primary)' : 'background:#fff;color:var(--color-ink-soft);border:1px solid rgba(150,129,107,0.20)'}" %>
        <% end %>
      </div>
    <% end %>

    <% if @articles.any? %>
      <div class="space-y-10">
        <% @articles.each_with_index do |article, idx| %>
          <%= link_to article_path(slug: article.slug), class: "block group", data: { controller: "reveal", reveal_delay: (idx * 100).to_s } do %>
            <div class="card-glass overflow-hidden" style="border-radius:16px">
              <% if article.cover_image.attached? %>
                <div class="overflow-hidden" style="height:280px">
                  <%= image_tag article.cover_image.variant(resize_to_fill: [900, 400]), class: "w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" %>
                </div>
              <% end %>
              <div class="p-8">
                <div class="flex items-center gap-4 mb-4">
                  <% if article.category.present? %>
                    <span class="font-accent px-3 py-1 rounded-full" style="font-size:11px;font-weight:600;background:var(--color-blush);color:var(--color-rose);letter-spacing:0.5px"><%= article.category %></span>
                  <% end %>
                  <span class="font-body" style="font-size:12px;color:var(--color-taupe)"><%= article.published_at&.strftime("%d %b %Y") %></span>
                  <span class="font-body" style="font-size:12px;color:var(--color-taupe)"><%= article.reading_time %> min</span>
                </div>
                <h2 class="font-display transition-colors mb-3" style="font-size:24px;font-weight:700;color:var(--color-ink)" onmouseover="this.style.color='var(--color-primary)'" onmouseout="this.style.color='var(--color-ink)'"><%= article.title %></h2>
                <% if article.excerpt.present? %>
                  <p class="font-body" style="font-size:15px;color:var(--color-ink-soft);line-height:1.8"><%= article.excerpt %></p>
                <% end %>
                <span class="inline-flex items-center font-accent mt-4" style="font-size:14px;letter-spacing:0.5px;font-weight:600;color:var(--color-primary)">Lire l'article &rarr;</span>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-20">
        <p class="font-body" style="font-size:16px;color:var(--color-taupe)">Les articles arrivent bientôt...</p>
      </div>
    <% end %>
  </div>
</section>

<%= render "shared/footer" %>
