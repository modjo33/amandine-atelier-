# Secrets chargés par Kamal au déploiement. NE PAS commit avec des vraies valeurs.
# Ces variables doivent exister en local (export en shell ou fichier ~/.amandine_env source).

# === Docker Hub registry password (access token recommandé) ===
# Crée un token sur https://hub.docker.com/settings/security puis :
#   export KAMAL_REGISTRY_PASSWORD=dckr_pat_xxx
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# === Rails master key (lue depuis le fichier) ===
RAILS_MASTER_KEY=$(cat config/master.key)

# === SMTP Brevo (https://app.brevo.com/settings/keys/smtp) ===
# Login Brevo → Paramètres → SMTP & API → Clés SMTP
# user = ton email Brevo, password = la clé SMTP générée
#   export BREVO_SMTP_USER=ton.email@example.com
#   export BREVO_SMTP_PASSWORD=xsmtpsib-xxxxx
BREVO_SMTP_USER=$BREVO_SMTP_USER
BREVO_SMTP_PASSWORD=$BREVO_SMTP_PASSWORD
